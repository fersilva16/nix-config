--- a/packages/tui/src/component/prompt/index.tsx	1969-12-31 21:00:01.000000000 -0300
+++ b/packages/tui/src/component/prompt/index.tsx	2026-07-14 14:52:51.995779577 -0300
@@ -158,6 +158,10 @@
   const project = useProject()
   const sync = useSync()
   const tuiConfig = useTuiConfig()
+  const cursorStyle = createMemo(() => ({
+    style: (tuiConfig.cursor_style ?? "block") as "block" | "line" | "underline",
+    blinking: tuiConfig.cursor_blink ?? true,
+  }))
   const dialog = useDialog()
   const toast = useToast()
   const status = createMemo(() => sync.data.session_status?.[props.sessionID ?? ""] ?? { type: "idle" })
@@ -1436,6 +1440,7 @@
               onMouseDown={(r: MouseEvent) => r.target?.focus()}
